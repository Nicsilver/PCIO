<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="dk.nicsilver.pcioServer.SettingsGUI">
  <grid id="27dc6" binding="settingsPanel" layout-manager="GridLayoutManager" row-count="3" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="10" left="10" bottom="10" right="10"/>
    <constraints>
      <xy x="20" y="20" width="1250" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="f5322" class="javax.swing.JLabel">
        <constraints>
