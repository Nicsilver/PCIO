<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context="dk.nicsilver.pcio.action.ActionActivity">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/mouse_fragment"
        android:name="dk.nicsilver.pcio.action.mouse.MouseFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout="@layout/mouse_fragment" />

    <!--    <fragment-->
    <!--        android:id="@+id/action_fragment_container"-->
    <!--        android:layout_width="match_parent"-->
    <!--        android:layout_height="match_parent" />-->

    <TextView
        android:id="@+id/keyboard_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="30sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/mouse_fragment" />

    <EditText

        android:id="@+id/keyboard_edit_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:alpha="0"
        android:cursorVisible="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/horizontalScrollView" />


    <HorizontalScrollView
        android:id="@+id/horizontalScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">


        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="horizontal">


            <ImageButton

                android:id="@+id/keyboard_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="20dp"
                android:background="?android:selectableItemBackgroundBorderless"
                android:contentDescription="@string/keyboard_button"
                android:padding="0dp"
                android:src="@drawable/ic_baseline_keyboard_50" />

            <ImageButton
                android:id="@+id/media_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="20dp"
                android:background="?android:selectableItemBackgroundBorderless"
                android:contentDescription="@string/media_keys_button"
                android:padding="0dp"
                android:src="@drawable/ic_baseline_play_circle_outline_50" />

            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="20dp"
                android:background="?android:selectableItemBackgroundBorderless"
                android:contentDescription="@string/media_keys_button"
                android:padding="0dp"
                android:src="@drawable/ic_baseline_power_settings_new_50" />

            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="20dp"
                android:background="?android:selectableItemBackgroundBorderless"
                android:contentDescription="@string/media_keys_button"
                android:padding="0dp"
                android:src="@drawable/ic_baseline_keyboard_50" />

            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="20dp"
                android:background="?android:selectableItemBackgroundBorderless"
                android:contentDescription="@string/media_keys_button"
                android:padding="0dp"
                android:src="@drawable/ic_baseline_keyboard_50" />

            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="20dp"
                android:background="?android:selectableItemBackgroundBorderless"
                android:contentDescription="@string/media_keys_button"
                android:padding="0dp"
                android:src="@drawable/ic_baseline_keyboard_50" />

            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="20dp"
                android:background="?android:selectableItemBackgroundBorderless"
                android:contentDescription="@string/media_keys_button"
                android:padding="0dp"
                android:src="@drawable/ic_baseline_keyboard_50" />

            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="20dp"
                android:background="?android:selectableItemBackgroundBorderless"
                android:contentDescription="@string/media_keys_button"
                android:padding="0dp"
                android:src="@drawable/ic_baseline_keyboard_50" />

        </LinearLayout>
    </HorizontalScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>